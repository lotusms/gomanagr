{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/server/*": ["server/*"],
      "@/lib/*": ["lib/*"],
      "@/services/*": ["services/*"],
      "@/utils/*": ["utils/*"],
      "@/config/*": ["config/*"],
      "@/components/*": ["components/*"],
      "@/styles/*": ["styles/*"],
      "@/pages/*": ["pages/*"]
    }
  },
  "exclude": ["node_modules", ".next"]
}
