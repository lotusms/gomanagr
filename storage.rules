rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if the path userId matches the authenticated user's UID
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Company logos - stored at company-logos/{userId}/{filename}
    match /company-logos/{userId}/{fileName} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId)
                 && request.resource.size < 5 * 1024 * 1024  // 5MB max
                 && request.resource.contentType.matches('image/.*');
      allow delete: if isOwner(userId);
    }
    
    // Team member photos - stored at team-photos/{userId}/{memberId}/{fileName}
    match /team-photos/{userId}/{memberId}/{fileName} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId)
                 && request.resource.size < 5 * 1024 * 1024  // 5MB max
                 && request.resource.contentType.matches('image/.*');
      allow delete: if isOwner(userId);
    }
    
    // Deny all other access by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
