# Supabase (required for app)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Supabase Service Role Key (for migration script only - keep secret!)
# Get from: Supabase Dashboard > Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Invite emails: GoManagr sends from your address; Reply-To = org admin who invited
# Gmail / Google Workspace: use smtp.gmail.com and an App Password (Google Account → Security → 2-Step Verification → App passwords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=info@lotusmarketingsolutions.com
SMTP_PASSWORD=your_google_app_password
SMTP_FROM_EMAIL=info@lotusmarketingsolutions.com
SMTP_FROM_NAME=GoManagr
# Option B — Resend (optional): RESEND_API_KEY=re_xxx, RESEND_FROM_EMAIL=invites@yourdomain.com
# If neither is set, invite link is copied to clipboard for manual sharing.

# App URL (optional). Invite links use this as base. Pay links use APP_BASE_URL first (see below).
# NEXT_PUBLIC_APP_URL=https://gomanagr.vercel.app

# Base URL for invoice "Pay now" links. Use the same domain you use to open the app (e.g. dashboard).
# Example: https://gomanagr.com (no trailing slash). Falls back to NEXT_PUBLIC_APP_URL then http://localhost:3000.
# APP_BASE_URL=https://gomanagr.com

# Payment (optional). See docs/PAYMENT_INTEGRATION.md. No monthly fee with Stripe.
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_...
# STRIPE_SECRET_KEY=sk_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Optional: secret for weekly invite cleanup cron (POST /api/cleanup-org-invites with header x-cron-secret).
# If set, cron can call the endpoint without a user session. Otherwise only a logged-in superadmin can run it.
# CRON_SECRET=your_random_secret_here

# Website consultation form: where to send requests (defaults to SMTP_FROM_EMAIL)
# WEBSITE_CONSULTATION_TO=info@lotusmarketingsolutions.com

